# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this example file is safe to commit.
#
# Everything below is OPTIONAL. With no keys, Connect runs fully on
# culturally-grounded fallbacks so the demo always works. Add a key to make the
# AI calls live (event generation, coordinator messages, and the cultural
# knowledge assistant).

# Anthropic / Claude API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Upstash Redis for the AI's analytics/memory layer. Without these,
# memory runs in-process. https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Poke webhook for phone-based community nudges. Without this,
# Connect logs demo pokes to the server console so the automation still demos.
# Expected request: POST JSON { to, name, reason, message, metadata }.
POKE_API_URL=
POKE_API_KEY=
